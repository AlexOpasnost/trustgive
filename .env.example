# TrustGive — Environment Variables Template
# Copy this file to .env and fill in real values. Never commit .env (see .gitignore).

# === Django ===
DJANGO_SECRET_KEY=replace-with-50-char-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,trustgive.up.railway.app
DJANGO_CSRF_TRUSTED_ORIGINS=https://trustgive.up.railway.app

# === Database ===
# In production: provided by Railway Postgres service via reference: ${{Postgres.DATABASE_URL}}
# Locally: point to a local Postgres or Docker container
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trustgive

# === External APIs (charity data sources) ===
# ProPublica Nonprofit Explorer API v2 — no key required, attribution required
PROPUBLICA_API_BASE=https://projects.propublica.org/nonprofits/api/v2

# Every.org Charity API — sign up at https://www.every.org/charity-api
EVERY_ORG_PUBLIC_KEY=replace-with-public-key
EVERY_ORG_PRIVATE_KEY=replace-with-private-key
EVERY_ORG_API_BASE=https://partners.every.org/v0.2

# CharityBase.uk — no key required for read
CHARITYBASE_API_BASE=https://charitybase.uk/api

# === Observability ===
SENTRY_DSN=https://your-key@sentry.io/your-project
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

POSTHOG_API_KEY=phc_your_key
POSTHOG_HOST=https://eu.i.posthog.com

# === Frontend (built-time, used by Vite) ===
VITE_API_BASE_URL=https://trustgive-backend.up.railway.app
VITE_POSTHOG_API_KEY=phc_your_key
VITE_POSTHOG_HOST=https://eu.i.posthog.com
VITE_SENTRY_DSN=https://your-key@sentry.io/your-frontend-project

# === Railway (CLI link, optional) ===
# RAILWAY_PROJECT_ID=09bd8e82-2325-4e13-8404-fe3f1832a0dd
# Use: railway link --project $RAILWAY_PROJECT_ID
RAILWAY_DEPLOYMENT_ID=local

# === App version (used by Sentry release tags + /api/health/) ===
APP_VERSION=1.0.0-dev

# === PostHog server-side mirror (per ADR-008) ===
# Public key lives in the frontend (.env.local for Vite). Server-side key kept here.
POSTHOG_SERVER_KEY=phc_server_key_here

# === Cloudflare CDN purge (per ADR-007) ===
# Token needs Zone:Cache Purge permission only.
CF_API_TOKEN=your-cloudflare-api-token
CF_ZONE_ID=your-cloudflare-zone-id
