# TrustGive web frontend — environment variables
# Local dev typically uses Vite dev-server proxy; in production set the absolute URL.

VITE_API_BASE_URL=http://localhost:8000

# PostHog public key (frontend client-side analytics)
VITE_POSTHOG_API_KEY=phc_public_key_here
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Sentry frontend DSN (separate project from backend)
VITE_SENTRY_DSN=
